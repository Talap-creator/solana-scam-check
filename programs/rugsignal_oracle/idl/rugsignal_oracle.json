{
  "version": "0.1.0",
  "name": "rugsignal_oracle",
  "instructions": [
    {
      "name": "initializeOracle",
      "accounts": [
        { "name": "oracleConfig", "isMut": true, "isSigner": false },
        { "name": "publisher", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "publishScore",
      "accounts": [
        { "name": "oracleConfig", "isMut": true, "isSigner": false },
        { "name": "tokenRiskScore", "isMut": true, "isSigner": false },
        { "name": "tokenMint", "isMut": false, "isSigner": false },
        { "name": "publisher", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "score", "type": "u8" },
        { "name": "riskLevel", "type": { "defined": "RiskLevel" } },
        { "name": "confidence", "type": "u8" }
      ]
    },
    {
      "name": "createVault",
      "accounts": [
        { "name": "userVault", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "riskThreshold", "type": "u8" }
      ]
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "userVault", "isMut": true, "isSigner": false },
        { "name": "vaultSol", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "guardedSwap",
      "accounts": [
        { "name": "userVault", "isMut": true, "isSigner": false },
        { "name": "tokenRiskScore", "isMut": false, "isSigner": false },
        { "name": "tokenMint", "isMut": false, "isSigner": false },
        { "name": "vaultSol", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "emergencyExit",
      "accounts": [
        { "name": "userVault", "isMut": true, "isSigner": false },
        { "name": "tokenRiskScore", "isMut": false, "isSigner": false },
        { "name": "tokenMint", "isMut": false, "isSigner": false },
        { "name": "vaultSol", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": true, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "updateThreshold",
      "accounts": [
        { "name": "userVault", "isMut": true, "isSigner": false },
        { "name": "owner", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "newThreshold", "type": "u8" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "OracleConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "publisher", "type": "publicKey" },
          { "name": "totalScoresPublished", "type": "u64" },
          { "name": "createdAt", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "TokenRiskScore",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "tokenMint", "type": "publicKey" },
          { "name": "score", "type": "u8" },
          { "name": "riskLevel", "type": { "defined": "RiskLevel" } },
          { "name": "confidence", "type": "u8" },
          { "name": "updatedAt", "type": "i64" },
          { "name": "publisher", "type": "publicKey" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "UserVault",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner", "type": "publicKey" },
          { "name": "balance", "type": "u64" },
          { "name": "riskThreshold", "type": "u8" },
          { "name": "createdAt", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "RiskLevel",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Low" },
          { "name": "Medium" },
          { "name": "High" },
          { "name": "Critical" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "InvalidScore", "msg": "Score must be between 0 and 100" },
    { "code": 6001, "name": "InvalidConfidence", "msg": "Confidence must be between 0 and 100" },
    { "code": 6002, "name": "InvalidThreshold", "msg": "Risk threshold must be between 0 and 100" },
    { "code": 6003, "name": "ZeroAmount", "msg": "Amount must be greater than zero" },
    { "code": 6004, "name": "InsufficientBalance", "msg": "Insufficient vault balance" },
    { "code": 6005, "name": "RiskTooHigh", "msg": "Token risk score exceeds vault threshold — swap rejected" },
    { "code": 6006, "name": "NotCritical", "msg": "Token is not in critical state (score < 75)" }
  ]
}
