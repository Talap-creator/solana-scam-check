HELIUS_API_KEY=your-helius-api-key
DATABASE_URL=postgresql+psycopg://rugsignal:rugsignal@127.0.0.1:5432/rugsignal
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_WINDOW_SECONDS=900
TOKEN_CHECK_RATE_LIMIT=30
TOKEN_CHECK_WINDOW_SECONDS=60
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://solanatrust.vercel.app
TOKEN_HOLDERS_MAX_PAGES=25
FEED_LIVE_SOURCE_ENABLED=true
FEED_LIVE_PROFILES_LIMIT=2
FEED_LIVE_SYNC_TTL_SECONDS=60
FREE_DAILY_SCAN_LIMIT=5
PRO_DAILY_SCAN_LIMIT=200
ENTERPRISE_DAILY_SCAN_LIMIT=1000
